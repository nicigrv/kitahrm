generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Domain ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          String    @default("KITA_STAFF") // ADMIN | KITA_MANAGER | KITA_STAFF

  kitaId        String?
  kita          Kita?     @relation(fields: [kitaId], references: [id])

  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Kita {
  id          String     @id @default(cuid())
  name        String
  shortCode   String     @unique
  address     String?
  phone       String?
  email       String?
  minFirstAid Int        @default(2)

  employees   Employee[]
  users       User[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Employee {
  id           String    @id @default(cuid())
  firstName    String
  lastName     String
  email        String?
  phone        String?
  address      String?
  birthDate    DateTime?
  position     String
  startDate    DateTime
  endDate      DateTime?
  contractType String    @default("UNBEFRISTET") // UNBEFRISTET|BEFRISTET|MINIJOB|AUSBILDUNG|PRAKTIKUM|ELTERNZEIT
  weeklyHours  Float     @default(39.0)
  isActive     Boolean   @default(true)
  notes        String?

  kitaId       String
  kita         Kita      @relation(fields: [kitaId], references: [id])

  documents    EmployeeDocument[]
  completions  TrainingCompletion[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([kitaId])
  @@index([isActive])
}

model EmployeeDocument {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  fileName    String
  storagePath String
  mimeType    String
  sizeBytes   Int
  label       String?
  uploadedAt  DateTime @default(now())

  @@index([employeeId])
}

// ─── Training & Certificates ─────────────────────────────────────────────────

model TrainingCategory {
  id             String   @id @default(cuid())
  name           String   @unique
  description    String?
  validityMonths Int?
  isFirstAid     Boolean  @default(false)
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)

  completions    TrainingCompletion[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model TrainingCompletion {
  id              String           @id @default(cuid())
  employeeId      String
  employee        Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  categoryId      String
  category        TrainingCategory @relation(fields: [categoryId], references: [id])

  completedDate   DateTime
  expiryDate      DateTime?
  notes           String?
  certificatePath String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([employeeId])
  @@index([categoryId])
  @@index([expiryDate])
}
