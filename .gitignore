# vendor/ wird BEWUSST eingecheckt, damit kein Composer auf dem Server nötig ist
/node_modules/
.env
.env.backup
.env.production

# Bootstrap-Cache: Verzeichnis behalten, generierte Dateien ignorieren
/bootstrap/cache/*.php
!/bootstrap/cache/.gitkeep

# Storage: Verzeichnisstruktur behalten, Inhalt ignorieren
/storage/framework/views/*
!/storage/framework/views/.gitkeep
/storage/framework/cache/data/*
!/storage/framework/cache/data/.gitkeep
/storage/framework/sessions/*
!/storage/framework/sessions/.gitkeep
/storage/logs/*
!/storage/logs/.gitkeep
/storage/app/documents/*
!/storage/app/documents/.gitkeep

.phpunit.result.cache
Thumbs.db
.DS_Store
