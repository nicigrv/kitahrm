# Datenbank (für Docker: Pfad im Volume)
DATABASE_URL="file:/app/data/production.db"

# Sicherheitsschlüssel – UNBEDINGT ändern!
# Generieren: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="hier-einen-langen-zufallsstring-eingeben"

# Öffentliche URL der Anwendung (Domain oder IP des Servers)
NEXTAUTH_URL="https://ihre-domain.de"

# Optionale Startpasswörter (nur beim allerersten Start relevant, danach ignoriert)
# ADMIN_PASSWORD="Admin123!"
# MANAGER_PASSWORD="Manager123!"
