Options -Indexes
Options +FollowSymLinks

RewriteEngine On

# Serve existing static files directly from public/
RewriteCond %{REQUEST_URI} !^/public/
RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f
RewriteRule ^(.*)$ public/$1 [L]

# Forward all other requests to public/index.php
# REDIRECT_URL will be set to the original REQUEST_URI so Laravel
# can auto-detect the installation subdirectory.
RewriteCond %{REQUEST_URI} !^/public/
RewriteRule ^(.*)$ public/index.php [L,QSA]
